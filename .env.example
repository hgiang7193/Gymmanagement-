# =============================================================================
# MYFIT — Full-stack environment example
# Copy to `.env` and fill in production values before `docker compose up -d`.
# =============================================================================

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=myfit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_PORT=5432

# ── Backend (Express API) ──────────────────────────────────────────────────
BACKEND_PORT=3000

# Generate strong random values:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
ACCESS_TOKEN_SECRET=replace_with_64_byte_random
REFRESH_TOKEN_SECRET=replace_with_different_64_byte_random
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── Frontend (Next.js) ─────────────────────────────────────────────────────
FRONTEND_PORT=3001

# Public URL of the API as the browser sees it. For local docker compose
# with default ports, use http://localhost:3000. In production behind
# a reverse proxy, set this to your public API domain.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ── Optional: DeepSeek tooling (legacy) ─────────────────────────────────────
# Only needed if you use the bundled DeepSeek CLI helper. Safe to ignore.
# DEEPSEEK_USE_LOCAL=true
# DEEPSEEK_MODEL=deepseek-coder:6.7b
# OLLAMA_HOST=http://localhost:11434
