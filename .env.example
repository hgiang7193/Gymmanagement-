# DeepSeek CLI Configuration
# Copy this file to .env and update with your settings

# ==========================================
# LOCAL MODE (Recommended - Free & Private)
# ==========================================

# Use local Ollama instead of cloud API
DEEPSEEK_USE_LOCAL=true

# Model to use (choose one):
# - deepseek-coder:1.3b  (Lightweight, 1GB, fast)
# - deepseek-coder:6.7b  (Recommended, 4GB, balanced)
# - deepseek-coder:33b   (Most capable, 19GB, best quality)
DEEPSEEK_MODEL=deepseek-coder:6.7b

# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# ==========================================
# CLOUD MODE (Optional - Requires API Key)
# ==========================================

# To use cloud mode, set:
# DEEPSEEK_USE_LOCAL=false
# DEEPSEEK_API_KEY=your_api_key_here

# Get your API key from: https://platform.deepseek.com/
