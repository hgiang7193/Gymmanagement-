{
  "name": "myfit-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "runtime:check": "node scripts/check-runtime-env.js",
    "db:bootstrap": "node src/db/bootstrap.js",
    "db:seed": "node src/db/seed.js",
    "start": "node src/server.js",
    "test:smoke": "node --experimental-strip-types scripts/smoke-test-trial-booking.ts",
    "validate:import": "node --experimental-strip-types scripts/validate-import-csv.ts",
    "import:csv": "node --experimental-strip-types scripts/import-csv-to-postgres.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  }
}
